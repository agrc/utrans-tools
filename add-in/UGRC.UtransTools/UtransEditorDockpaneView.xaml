<UserControl x:Class="UGRC.UtransTools.UtransEditorDockpaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:UGRC.UtransTools.Models"
             MinWidth="460">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <SolidColorBrush x:Key="HighlightYellowBrush" Color="#FFECB3" />
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <DataTemplate x:Key="CountyReadOnlyTemplate">
            <StackPanel>
                <TextBlock Text="{Binding FieldName}" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding CountyValue, Mode=OneWay}" IsReadOnly="True" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="UtransEditableTemplate">
            <StackPanel>
                <TextBlock Text="{Binding FieldName}" Style="{StaticResource FieldLabelStyle}">
                    <TextBlock.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding DataContext.ToggleFieldCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      CommandParameter="{Binding}" />
                    </TextBlock.InputBindings>
                </TextBlock>
                <TextBox Text="{Binding UtransValue, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="White" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDifferent}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource HighlightYellowBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="6" MinWidth="440">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding RemainingDfcRecords, StringFormat=Remaining: {0}, TargetNullValue='Remaining: unavailable'}"
                           VerticalAlignment="Top" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Update Change Type: " FontWeight="Bold" />
                    <TextBlock Text="{Binding ChangeTypeMessage}" Foreground="DarkGoldenrod" FontWeight="Bold" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                           Text="{Binding ReviewState.DfcRecordObjectId, StringFormat=DFC ObjectID: {0}}"
                           HorizontalAlignment="Right"
                           Visibility="{Binding HasReviewState, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>

            <GroupBox Grid.Row="1"
                      Header="{Binding ReviewState.CountyRecordObjectId}"
                      HeaderStringFormat="Selected County Road Segment ({0})"
                      Margin="3">
                <Grid IsEnabled="{Binding HasReviewState}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <GroupBox Header="Primary Attributes" Padding="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="80" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ContentControl Grid.Row="0" Grid.RowSpan="2" Content="{Binding AvailableReviewState.FromaddrL}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Content="{Binding AvailableReviewState.ToaddrL}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.Column="2" Content="{Binding AvailableReviewState.Predir}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.Column="3" Content="{Binding AvailableReviewState.Name}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.Column="4" Content="{Binding AvailableReviewState.Posttype}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.Column="5" Content="{Binding AvailableReviewState.Postdir}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" />
                            <ContentControl Grid.Row="1" Grid.Column="0" Content="{Binding AvailableReviewState.FromaddrR}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,4,4,0" />
                            <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding AvailableReviewState.ToaddrR}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,4,4,0" />
                        </Grid>
                    </GroupBox>
                    <GroupBox Grid.Column="1" Header="Alias Attributes" Padding="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="60" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ContentControl Grid.Row="0" Content="{Binding AvailableReviewState.A1Predir}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.Column="1" Content="{Binding AvailableReviewState.A1Name}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.Column="2" Content="{Binding AvailableReviewState.A1Posttype}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.Column="3" Content="{Binding AvailableReviewState.A1Postdir}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="1" Content="{Binding AvailableReviewState.A2Predir}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,4,4,0" />
                            <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding AvailableReviewState.A2Name}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,4,4,0" />
                            <ContentControl Grid.Row="1" Grid.Column="2" Content="{Binding AvailableReviewState.A2Posttype}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,4,4,0" />
                            <ContentControl Grid.Row="1" Grid.Column="3" Content="{Binding AvailableReviewState.A2Postdir}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,4,4,0" />
                            <ContentControl Grid.Row="0" Grid.RowSpan="2" Grid.Column="4" Content="{Binding AvailableReviewState.AnName}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.RowSpan="2" Grid.Column="5" Content="{Binding AvailableReviewState.AnPostdir}" ContentTemplate="{StaticResource CountyReadOnlyTemplate}" />
                        </Grid>
                    </GroupBox>
                </Grid>
            </GroupBox>

            <Button Grid.Row="2" Content="Transfer all values" Command="{Binding TransferAllCommand}" CommandParameter="{Binding ReviewState}" HorizontalAlignment="Center" Width="300" Height="25" IsEnabled="{Binding HasReviewState}" />

            <GroupBox Grid.Row="3"
                      Header="{Binding ReviewState.UtransRecordObjectId}"
                      HeaderStringFormat="Target UTrans Road Segment ({0})"
                      Margin="3">
                <Grid IsEnabled="{Binding HasReviewState}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <GroupBox Header="Primary Attributes" Padding="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="80" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ContentControl Grid.Row="0" Grid.RowSpan="2" Content="{Binding AvailableReviewState.FromaddrL}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Content="{Binding AvailableReviewState.ToaddrL}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.Column="2" Content="{Binding AvailableReviewState.Predir}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.Column="3" Content="{Binding AvailableReviewState.Name}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.Column="4" Content="{Binding AvailableReviewState.Posttype}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.Column="5" Content="{Binding AvailableReviewState.Postdir}" ContentTemplate="{StaticResource UtransEditableTemplate}" />
                            <ContentControl Grid.Row="1" Grid.Column="0" Content="{Binding AvailableReviewState.FromaddrR}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,4,4,0" />
                            <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding AvailableReviewState.ToaddrR}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,4,4,0" />
                        </Grid>
                    </GroupBox>
                    <GroupBox Grid.Column="1" Header="Alias Attributes" Padding="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="60" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ContentControl Grid.Row="0" Content="{Binding AvailableReviewState.A1Predir}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.Column="1" Content="{Binding AvailableReviewState.A1Name}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.Column="2" Content="{Binding AvailableReviewState.A1Posttype}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.Column="3" Content="{Binding AvailableReviewState.A1Postdir}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="1" Content="{Binding AvailableReviewState.A2Predir}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,4,4,0" />
                            <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding AvailableReviewState.A2Name}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,4,4,0" />
                            <ContentControl Grid.Row="1" Grid.Column="2" Content="{Binding AvailableReviewState.A2Posttype}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,4,4,0" />
                            <ContentControl Grid.Row="1" Grid.Column="3" Content="{Binding AvailableReviewState.A2Postdir}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,4,4,0" />
                            <ContentControl Grid.Row="0" Grid.RowSpan="2" Grid.Column="4" Content="{Binding AvailableReviewState.AnName}" ContentTemplate="{StaticResource UtransEditableTemplate}" Margin="0,0,4,0" />
                            <ContentControl Grid.Row="0" Grid.RowSpan="2" Grid.Column="5" Content="{Binding AvailableReviewState.AnPostdir}" ContentTemplate="{StaticResource UtransEditableTemplate}" />
                        </Grid>
                    </GroupBox>
                </Grid>
            </GroupBox>

            <Grid Grid.Row="4" Margin="3" IsEnabled="{Binding HasReviewState}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" MinWidth="150" />
                    <ColumnDefinition Width="*" MinWidth="130" />
                    <ColumnDefinition Width="*" MinWidth="130" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <GroupBox Header="Split a line OR wrong segment ID?">
                    <Button Content="Update DFC ObjectID" Command="{Binding UpdateDfcObjectIdCommand}" Margin="3" />
                </GroupBox>
                <GroupBox Grid.Column="1" Header="CARTOCODE">
                    <GroupBox.Style>
                        <Style TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ReviewState.IsCartocodeChanged}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource HighlightYellowBrush}" />
                                    <Setter Property="BorderThickness" Value="3" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </GroupBox.Style>
                    <ComboBox ItemsSource="{Binding CartocodeValues}"
                              DisplayMemberPath="Description"
                              SelectedValuePath="Code"
                              SelectedValue="{Binding ReviewState.Cartocode}"
                              Margin="3" />
                </GroupBox>
                <GroupBox Grid.Column="2" Header="ONEWAY">
                    <GroupBox.Style>
                        <Style TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ReviewState.IsOnewayChanged}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource HighlightYellowBrush}" />
                                    <Setter Property="BorderThickness" Value="3" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </GroupBox.Style>
                    <ComboBox ItemsSource="{Binding OnewayValues}"
                              DisplayMemberPath="Description"
                              SelectedValuePath="Code"
                              SelectedValue="{Binding ReviewState.Oneway}"
                              Margin="3" />
                </GroupBox>
                <GroupBox Grid.Column="3" Header="Change Status">
                    <ComboBox ItemsSource="{Binding DfcStatusValues}" SelectedItem="{Binding ReviewState.DfcStatus}" Margin="3" />
                </GroupBox>
                <Button Grid.Column="4" Content="Next" Command="{Binding NextCommand}" CommandParameter="{Binding ReviewState}" FontSize="12" FontWeight="Bold" Height="50" Width="150" VerticalAlignment="Center" Margin="3" Grid.RowSpan="2" />

                <StackPanel  Grid.Row="1" Margin="3" VerticalAlignment="Bottom">
                    <TextBlock VerticalAlignment="Bottom"
                        Text="UTrans Database Version:" />
                    <TextBlock VerticalAlignment="Bottom"
                        Text="{Binding UtransDatabaseVersion}" />
                </StackPanel>

                <GroupBox Grid.Row="1" Grid.Column="1" Header="VERT_LEVEL">
                    <GroupBox.Style>
                        <Style TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ReviewState.IsVerticalLevelChanged}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource HighlightYellowBrush}" />
                                    <Setter Property="BorderThickness" Value="3" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </GroupBox.Style>
                    <ComboBox ItemsSource="{Binding VerticalLevelValues}"
                              DisplayMemberPath="Description"
                              SelectedValuePath="Code"
                              SelectedValue="{Binding ReviewState.VerticalLevel}"
                              Margin="3" />
                </GroupBox>
                <GroupBox Grid.Row="1" Grid.Column="2" Header="SPEED_LMT">
                    <GroupBox.Style>
                        <Style TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ReviewState.IsSpeedLimitChanged}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource HighlightYellowBrush}" />
                                    <Setter Property="BorderThickness" Value="3" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </GroupBox.Style>
                    <ComboBox ItemsSource="{Binding SpeedLimitValues}" SelectedItem="{Binding ReviewState.SpeedLimit}" Margin="3" />
                </GroupBox>
                <Button Grid.Row="1" Grid.Column="3" Height="25" Content="Save in UTRANS" Command="{Binding SaveCommand}" VerticalAlignment="Center" Margin="6" />
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
